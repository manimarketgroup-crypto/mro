<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sign In — MANI Research</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Outfit:wght@400;700;800;900&family=JetBrains+Mono:wght@400&display=swap');
:root{--void:#03040A;--surface:#0A0D18;--raised:#0E1220;--hover:#131728;--g1:#00FFB2;--g2:#00D4FF;--p1:#9B6DFF;--pk:#FF6B9D;--am:#FFBE0B;--bl:#60C8FF;--t1:#F0F2FA;--t2:#8B96B0;--t3:#3D4A6B;--ti:#03040A;--b1:rgba(255,255,255,0.04);--b2:rgba(255,255,255,0.08);--b3:rgba(255,255,255,0.14);--fd:'Outfit',sans-serif;--fb:'Space Grotesk',sans-serif;--fm:'JetBrains Mono',monospace;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--fb);background:var(--void);color:var(--t1);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;-webkit-font-smoothing:antialiased;position:relative;}
body::before{content:'';position:fixed;inset:0;pointer-events:none;background:radial-gradient(ellipse 70% 60% at 20% 0%,rgba(0,255,178,0.06) 0%,transparent 55%),radial-gradient(ellipse 50% 40% at 80% 100%,rgba(155,109,255,0.07) 0%,transparent 55%);}
body::after{content:'';position:fixed;inset:0;pointer-events:none;background-image:radial-gradient(1px 1px at 20% 30%,rgba(255,255,255,0.35) 0%,transparent 100%),radial-gradient(1px 1px at 60% 15%,rgba(255,255,255,0.3) 0%,transparent 100%),radial-gradient(1px 1px at 80% 70%,rgba(255,255,255,0.25) 0%,transparent 100%),radial-gradient(1.5px 1.5px at 40% 80%,rgba(0,255,178,0.4) 0%,transparent 100%);}
::-webkit-scrollbar{width:3px;}::-webkit-scrollbar-thumb{background:var(--raised);}

.wrap{position:relative;z-index:1;width:100%;max-width:420px;animation:up .4s cubic-bezier(0.16,1,0.3,1);}
@keyframes up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}

/* Brand */
.brand{text-align:center;margin-bottom:32px;}
.logo-ring{width:52px;height:52px;border-radius:50%;background:radial-gradient(circle,rgba(0,255,178,0.2),rgba(0,255,178,0.05));border:1.5px solid rgba(0,255,178,0.4);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;box-shadow:0 0 30px rgba(0,255,178,0.15);}
.brand-n{font-family:var(--fd);font-size:22px;font-weight:900;letter-spacing:.06em;background:linear-gradient(135deg,#fff,var(--g1));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:block;line-height:1;}
.brand-s{font-size:11px;color:var(--t3);letter-spacing:.08em;display:block;margin-top:3px;}

/* Card */
.card{background:rgba(14,18,32,0.9);border:1px solid var(--b3);border-radius:20px;padding:36px;backdrop-filter:blur(20px);}
.card-title{font-family:var(--fd);font-size:22px;font-weight:800;margin-bottom:6px;color:var(--t1);}
.card-sub{font-size:13px;color:var(--t3);margin-bottom:28px;line-height:1.5;}

/* Form */
.fg{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
.fl{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t3);}
.fi{background:rgba(3,4,10,0.7);border:1px solid var(--b2);border-radius:10px;padding:11px 14px;color:var(--t1);font-family:var(--fb);font-size:14px;outline:none;width:100%;transition:border-color .2s,box-shadow .2s;}
.fi:focus{border-color:rgba(0,255,178,0.5);box-shadow:0 0 0 3px rgba(0,255,178,0.07);}
.fi::placeholder{color:var(--t3);}
.fi-wrap{position:relative;}
.fi-wrap .fi{padding-right:42px;}
.eye-btn{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--t3);cursor:pointer;padding:4px;}
.eye-btn:hover{color:var(--t2);}

.forgot{display:block;text-align:right;font-size:12px;color:var(--g1);margin-top:-8px;margin-bottom:18px;transition:opacity .15s;}
.forgot:hover{opacity:.75;}

.btn-main{width:100%;background:linear-gradient(135deg,var(--g1),var(--g2));color:var(--ti);border:none;border-radius:999px;padding:13px;font-family:var(--fb);font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;box-shadow:0 0 24px rgba(0,255,178,0.2);margin-top:4px;}
.btn-main:hover{transform:translateY(-2px);box-shadow:0 6px 30px rgba(0,255,178,0.3);}
.btn-main:disabled{opacity:.5;cursor:not-allowed;transform:none;}

.divider{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--t3);font-size:12px;}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--b2);}

.switch{text-align:center;font-size:13px;color:var(--t3);}
.switch a{color:var(--g1);font-weight:600;}

.err{background:rgba(255,107,157,0.1);border:1px solid rgba(255,107,157,0.3);color:var(--pk);font-size:13px;padding:11px 14px;border-radius:10px;margin-bottom:16px;display:none;line-height:1.5;}
.ok{background:rgba(0,255,178,0.08);border:1px solid rgba(0,255,178,0.25);color:var(--g1);font-size:13px;padding:11px 14px;border-radius:10px;margin-bottom:16px;display:none;line-height:1.5;}
</style>
</head>
<body>
<div class="wrap">
  <div class="brand">
    <div class="logo-ring">
      <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="14" stroke="#00FFB2" stroke-width="1.5"/>
        <circle cx="16" cy="16" r="3.5" fill="#00FFB2"/>
        <line x1="16" y1="2" x2="16" y2="9" stroke="#00FFB2" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="16" y1="23" x2="16" y2="30" stroke="#00FFB2" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="2" y1="16" x2="9" y2="16" stroke="#00FFB2" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="23" y1="16" x2="30" y2="16" stroke="#00FFB2" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <span class="brand-n">MANI</span>
    <span class="brand-s">Multidisciplinary Advanced Network for Innovation</span>
  </div>

  <div class="card">
    <h2 class="card-title">Welcome back</h2>
    <p class="card-sub">Sign in to your research account to continue</p>

    <div class="err" id="err"></div>
    <div class="ok"  id="ok"></div>

    <form onsubmit="doLogin(event)">
      <div class="fg">
        <label class="fl">Email address</label>
        <input class="fi" type="email" id="email" placeholder="you@university.edu" required autocomplete="email"/>
      </div>
      <div class="fg">
        <label class="fl">Password</label>
        <div class="fi-wrap">
          <input class="fi" type="password" id="password" placeholder="••••••••" required autocomplete="current-password"/>
          <button type="button" class="eye-btn" onclick="togglePw()" id="eyeBtn">
            <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <a class="forgot" href="forgot-password.html">Forgot password?</a>
      <button class="btn-main" type="submit" id="btn">Sign In</button>
    </form>

    <div class="divider">or</div>
    <div class="switch">Don't have an account? <a href="signup.html">Create one free →</a></div>
  </div>
</div>

<script>
const API = 'http://localhost:5000/api';
const auth = {
  loggedIn() { return !!localStorage.getItem('mani_token'); },
  set(t,u) { localStorage.setItem('mani_token',t); localStorage.setItem('mani_user',JSON.stringify(u)); }
};
if (auth.loggedIn()) location.href = '../index.html';

let pwVis = false;
function togglePw() {
  pwVis = !pwVis;
  const inp = document.getElementById('password');
  inp.type = pwVis ? 'text' : 'password';
  document.getElementById('eyeIcon').innerHTML = pwVis
    ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>'
    : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
}

async function doLogin(e) {
  e.preventDefault();
  const btn = document.getElementById('btn');
  const err = document.getElementById('err');
  const ok  = document.getElementById('ok');
  err.style.display = 'none'; ok.style.display = 'none';
  btn.disabled = true; btn.textContent = 'Signing in…';

  try {
    const r = await fetch(API + '/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email:    document.getElementById('email').value.trim(),
        password: document.getElementById('password').value
      })
    });
    const d = await r.json();
    if (!r.ok) throw new Error(d.error || d.errors?.[0]?.msg || 'Login failed');
    auth.set(d.token, d.user);
    ok.textContent = '✓ Signed in! Redirecting…';
    ok.style.display = 'block';
    const redir = new URLSearchParams(location.search).get('redirect') || '../index.html';
    setTimeout(() => location.href = redir, 700);
  } catch (ex) {
    err.textContent = ex.message;
    err.style.display = 'block';
    btn.disabled = false; btn.textContent = 'Sign In';
  }
}
</script>
</body>
</html>
